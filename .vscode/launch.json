{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/todo/main.go",
            "args": [],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "LOGGER_FOLDER": "${workspaceFolder}/out/logs",
                "POSTGRES_HOST": "localhost"
            }
        },
        {
            "name": "Launch File",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${file}"
        },
        {
            "name": "Run Tests",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}"
        }
    ]
}